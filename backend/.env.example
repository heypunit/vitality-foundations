# .env.example – copy to .env and fill values

# SendGrid (or Mailgun) configuration – replace with your own API key
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
# Email address that will receive contact form submissions
TO_EMAIL=yourbusiness@example.com
# Email address that will appear as the sender (must be verified in SendGrid)
FROM_EMAIL=noreply@yourdomain.com

# Simple admin token for protecting admin routes (choose a strong random string)
ADMIN_TOKEN=YOUR_RANDOM_ADMIN_TOKEN

# Server port (default 3000)
PORT=3000
