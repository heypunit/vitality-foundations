# Vitality Foundations - Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=production

# Your website name (used in emails)
SITE_NAME=Vitality Foundations
SITE_URL=https://your-domain.com

# CORS - comma-separated list of allowed frontend origins
# Include your live domain and any development URLs
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-domain.com

# Admin Dashboard Protection
# Generate a strong random string: https://randomkeygen.com/
ADMIN_API_KEY=your-super-secret-admin-key-change-this
ADMIN_URL=https://your-domain.com/admin

# Email Configuration (Gmail SMTP example)
# For Gmail: Use an App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where to send notification emails (your admin email)
NOTIFY_EMAIL=your-email@gmail.com

# Optional: SendGrid or other SMTP provider
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
